const ExperienceCard = ({ role, company, duration, description, index, category }) => {
  const { theme } = useTheme();
  const ref = useRef(null);
  const isInView = useInView(ref, { once: false, amount: 0.4 });

  return (
    <motion.div
      ref={ref}
      initial={{ opacity: 0, x: index % 2 === 0 ? -30 : 30 }}
      animate={isInView ? { opacity: 1, x: 0 } : { opacity: 0, x: index % 2 === 0 ? -30 : 30 }}
      transition={{ duration: 0.7, delay: 0.1 }}
      data-category={category}
    >
      <LiquidGlassPanel className="p-6 h-full">
        <div className="flex items-start justify-between mb-4">
          <div>
            <h3 className="text-xl font-bold" style={{ color: theme.colors.text }}>
              {role}
            </h3>
            <p className="font-semibold" style={{ color: theme.colors.accentAlt }}>
              {company}
            </p>
          </div>
          <span className="text-sm px-3 py-1 rounded-full backdrop-blur-sm border"
            style={{
              backgroundColor: theme.colors.card,
              borderColor: theme.colors.border,
              color: theme.colors.textSecondary,
            }}
          >
            {duration}
          </span>
        </div>
        <p style={{ color: theme.colors.textSecondary }}>
          {description}
        </p>
      </LiquidGlassPanel>
    </motion.div>
  );
};

